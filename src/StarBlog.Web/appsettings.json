{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/starblog-web-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "flushToDiskInterval": "00:00:01",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SQLite": "Data Source=app.db;Synchronous=Off;Cache Size=5000;",
    "SQLite-Log": "Data Source=app.log.db;"
  },
  "Outbox": {
    "BatchSize": 20,
    "PollInterval": "00:00:00.500",
    "LeaseDuration": "00:01:00",
    "MaxBackoff": "00:10:00",
    "BackoffJitter": "00:00:00.500",
    "DefaultMaxAttempts": 5
  },
  "Auth": {
    "Jwt": {
      "Issuer": "starblog",
      "Audience": "starblog-admin-ui",
      "Key": "Pox40XC.D5>v^2B7+KAt%WfXaz0B6zC5"
    }
  },
  "Bootstrap": {
    "Enabled": true,
    "RunLogDatabaseMigrations": true,
    "SeedAdmin": false,
    "AdminUsername": "admin",
    "AdminPassword": ""
  },
  "Translation": {
    "LLM": {
      "Endpoint": "https://api.openai.com/v1",
      "Key": "",
      "Model": "gpt-4o-mini"
    },
    "TargetLanguage": "en",
    "MaxContentLength": 6000,
    "MaxRetries": 3
  }
}
